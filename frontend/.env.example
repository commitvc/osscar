# Copy to frontend/.env.local and fill in real values.
# frontend/.env.local is gitignored by Next.js by default.

# ── Site ──────────────────────────────────────────────────────────────────────
# Used to render absolute URLs in transactional emails (logo, CTA links).
NEXT_PUBLIC_SITE_URL=https://osscar.dev

# ── Supabase ──────────────────────────────────────────────────────────────────
# https://<project-ref>.supabase.co
SUPABASE_URL=https://eoblveaskkjopnlfkwtf.supabase.co
# Project Settings → API → service_role (secret). Server-only — NEVER NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# ── Resend ────────────────────────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=
# Leave unset during dev to fall back to Resend's shared test sender
# (onboarding@resend.dev → delivers only to your Resend account email).
# Flip to your verified domain once DNS is green.
RESEND_FROM=OSSCAR <hello@osscar.dev>

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
# dash.cloudflare.com → Turnstile → Create site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Rate limits (optional overrides) ─────────────────────────────────────────
RATE_LIMIT_EMAIL_PER_DAY=3
RATE_LIMIT_IP_PER_DAY=10
